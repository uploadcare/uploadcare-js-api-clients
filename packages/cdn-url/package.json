  "scripts": {
    "prepack": "cp ../../LICENSE ./LICENSE",
    "clean": "rimraf dist",
    "test": "vitest --run --coverage",
    "test:watch": "vitest",
    "prebuild": "npm run clean",
    "build": "tsc && vite build && vite build --mode development && vite build --mode iife && node scripts/verify-bundles.mjs && node scripts/smoke-node.mjs",
    "docs:api": "typedoc --validation.notDocumented --treatValidationWarningsAsErrors",
    "docs:dev": "npm run docs:api && vitepress dev docs",
    "docs:build": "npm run docs:api && vitepress build docs",
    "lint": "oxlint src",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "test:browser": "vitest --run --config vitest.browser.config.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uploadcare/uploadcare-js-api-clients.git"
